    <Method Name="mRealeaseCurrentJob" Id="{7dfd8ad7-dbfa-4800-8f47-7a8acf353eca}" FolderPath="02 Methodes\200 Cmd RoueExecutor\">
      <Declaration><![CDATA[METHOD mRealeaseCurrentJob : E_CmdState
VAR_INPUT
END_VAR

VAR
	L_eCmdState : E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Notify the RouteManager that the job is complete and release the resources
// Check route provider
IF itfRouteProvider = 0 
	THEN
    mRealeaseCurrentJob := E_CmdState.NotReady;
    RETURN;
END_IF

// Check current job pointer
IF pstCurrentJob = 0 
	THEN
    mRealeaseCurrentJob := E_CmdState.NotReady;
    RETURN;
END_IF

// Tell RouteManager to release route resources
L_eCmdState := itfRouteProvider.mReleaseRoute(pstCurrentJob^.uiJobID);

// Evaluate release result
IF L_eCmdState = E_CmdState.Succeeded 
	THEN
    // Mark local executor state as free
    bJobActive 					:= FALSE;
    // Reset step counter
    uiCurrentStep 			:= 0;
    // Clear pointer to avoid using an old job
    pstCurrentJob 			:= 0;
    mRealeaseCurrentJob := E_CmdState.Succeeded;
    RETURN;
END_IF
// Release failed
mRealeaseCurrentJob := L_eCmdState;

]]></ST>
      </Implementation>
    </Method>
    <Method Name="mRelease" Id="{53d477d2-f31b-49d2-807b-dd9cc171f4a0}" FolderPath="02 Methodes\400 Fx\">
      <Declaration><![CDATA[METHOD mRelease : E_CmdState
VAR_INPUT
