<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FD_RouteExecutorDevice" Id="{a029717b-dfa2-4581-b4e8-7347f75dc7f5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FD_RouteExecutorDevice EXTENDS FD_Device 
VAR_INPUT
END_VAR

VAR_OUTPUT
END_VAR

VAR
	//===================== interface
 	itfLTU3  											: ITF_LTU;
 	itfLTU6  											: ITF_LTU;
 	itfLTU9  											: ITF_LTU;
 	itfLTU12 											: ITF_LTU;
          											
	itfC3    											: ITF_Convoyer;
	itfC6    											: ITF_Convoyer;
	itfC9    											: ITF_Convoyer;
	itfC12   											: ITF_Convoyer;
	
	itfRouteProvider							: ITF_RouteProvider;
	
	
	//===================== Variable
	// Ich muss Pointer verwenden, weil der RouteExecutor direkt mit dem echten Job arbeiten muss, 
  //der im RouteManager gespeichert ist.
	pstCurrentJob 								: POINTER TO ST_RouteJob; //
	
	uiCurrentStep 								: UINT; // Current route step index
	bJobActive 										: BOOL; // TRUE while executor is processing a route
	
	
	//===================== Instance

																								
END_VAR

VAR CONSTANT
	// --------------------------Base------------------
	C_SeqStep_OnBasePos_Start															: UINT :=  1; 
	C_SeqStep_OnBasePos_Error															: UINT :=  30;
	C_SeqStep_OnBasePos_Done															: UINT :=  100; 

	// --------------------------Auto Sequence------------------
	C_SeqStep_Auto_Start																	: UINT :=  1;
	C_SeqStep_Auto_Execute_GetNext_Route_Job							: UINT :=  10;
	C_SeqStep_Auto_Execute_Current_Route_Step							: UINT :=  20;
	C_SeqStep_Auto_Release_Current_Job										: UINT :=  30;
	C_SeqStep_Auto_Error																	: UINT :=  40;
	C_SeqStep_Auto_End																		: UINT :=  50;
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//******* Important and necessary
SUPER^();  
//====================================
IF NOT Enable THEN RETURN; END_IF

]]></ST>
    </Implementation>
    <Folder Name="01 Properties" Id="{eac2aa03-7ea6-4d75-a023-a13fe1428527}" />
    <Folder Name="02 Methodes" Id="{717c44f6-c96e-41a8-89f5-06b22d0c9069}">
      <Folder Name="100 CmdExecute" Id="{c0ec372c-0671-4b3a-a8b5-4fce6e412148}" />
      <Folder Name="200 Cmd RoueExecutor" Id="{eacbc3a0-13e3-467d-bf05-4faf01046530}" />
