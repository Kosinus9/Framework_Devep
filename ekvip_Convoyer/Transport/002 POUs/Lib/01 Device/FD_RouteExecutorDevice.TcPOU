END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
SUPER^.mRelease(I_bExecute);]]></ST>
      </Implementation>
    </Method>
    <Method Name="mSequence" Id="{f40f09ba-b814-4a11-a73f-f4ac5b8d4cc1}" FolderPath="02 Methodes\">
      <Declaration><![CDATA[METHOD mSequence : E_CmdState
VAR_INPUT
	I_bExecute		 : BOOL;
END_VAR

VAR_INST
	L_eCmdState 	 : E_CmdState; // To Generic checks from parent state 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// Generic checks from parent
L_eCmdState := SUPER^.mSequence(I_bExecute := I_bExecute);

IF L_eCmdState <> E_CmdState.Busy 
	THEN
    mSequence := L_eCmdState;
    RETURN;
END_IF

CASE Mode OF
	E_Mode.Homing:
		mSequence := mCmdExec_BasePos();
	E_Mode.Auto:
		mSequence := mCmdExec_Auto();		
	E_Mode.Service:
		mSequence := mCmdExec_Service();		
END_CASE
]]></ST>
      </Implementation>
    </Method>
