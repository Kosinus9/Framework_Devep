    <Method Name="FB_Init" Id="{30bf4515-e308-418c-87d1-6b7687fa091c}" FolderPath="02 Methodes\">
      <Declaration><![CDATA[//FB_Init ist immer implizit verfügbar und wird primär für die Initialisierung verwendet.
//Der Rückgabewert wird nicht ausgewertet. Für gezielte Einflussnahme können Sie
//die Methoden explizit deklarieren und darin mit dem Standard-Initialisierungscode 
//zusätzlichen Code bereitstellen. Sie können den Rückgabewert auswerten.
METHOD FB_Init: BOOL
VAR_INPUT    
	bInitRetains					: BOOL; 					// TRUE: Die Retain-Variablen werden initialisiert (Reset warm / Reset kalt)    
	bInCopyCode						: BOOL;  					// TRUE: Die Instanz wird danach in den Kopiercode kopiert (Online-Change)
	
	I_Name                : STRING;         //  Name
	I_ID                  : UINT;           // ID
  I_itfOwner					  : ITF_Owner;      // owner 
	
	// ITF_LTU	
	I_itfLTU3  						: ITF_LTU;        
 	I_itfLTU6  						: ITF_LTU;
 	I_itfLTU9  						: ITF_LTU;
 	I_itfLTU12 						: ITF_LTU;
	
	// ITF_Convoyer  							
	I_itfC3    						: ITF_Convoyer;
	I_itfC6    						: ITF_Convoyer;
	I_itfC9    						: ITF_Convoyer;
	I_itfC12   						: ITF_Convoyer;
	// Route Provider
	I_itfRouteProvider		: ITF_RouteProvider;
END_VAR



]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// chek and link LTU
IF I_itfLTU3  <>0 THEN itfLTU3  := I_itfLTU3; END_IF
IF I_itfLTU6  <>0 THEN itfLTU6  := I_itfLTU6; END_IF
IF I_itfLTU9  <>0 THEN itfLTU9  := I_itfLTU9; END_IF
IF I_itfLTU12 <>0 THEN itfLTU12 := I_itfLTU12;END_IF

// chek and link covoyer
IF I_itfC3  <>0 THEN itfC3  := I_itfC3; END_IF
IF I_itfC6  <>0 THEN itfC6  := I_itfC6; END_IF
IF I_itfC9  <>0 THEN itfC9  := I_itfC9; END_IF
IF I_itfC12 <>0 THEN itfC12 := I_itfC12;END_IF

// chek lind to Route manager
IF I_itfRouteProvider <>0 THEN itfRouteProvider := I_itfRouteProvider;END_IF


]]></ST>
      </Implementation>
    </Method>
    <Method Name="mAutomatic" Id="{a75fe4d4-7f2d-4070-80b3-f99e488c96ba}" FolderPath="02 Methodes\">
