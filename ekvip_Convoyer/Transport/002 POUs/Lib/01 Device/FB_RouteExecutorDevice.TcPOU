  <POU Name="FB_RouteExecutorDevice" Id="{a029717b-dfa2-4581-b4e8-7347f75dc7f5}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_RouteExecutorDevice EXTENDS FD_Device 
VAR_INPUT
END_VAR

VAR_OUTPUT
END_VAR

VAR
	//===================== interface
 	itfLTU3  											: ITF_LTU;
 	itfLTU6  											: ITF_LTU;
 	itfLTU9  											: ITF_LTU;
 	itfLTU12 											: ITF_LTU;
          											
	itfC3    											: ITF_Convoyer;
	itfC6    											: ITF_Convoyer;
	itfC9    											: ITF_Convoyer;
	itfC12   											: ITF_Convoyer;
	
	itfRouteProvider							: ITF_RouteProvider;
	//===================== Variable
	
	
	//===================== Instance

																								
END_VAR

VAR CONSTANT
	// --------------------------Base------------------
	C_SeqStep_OnBasePos_Start								: UINT :=  1; 
	C_SeqStep_OnBasePos_Error								: UINT :=  30;
	C_SeqStep_OnBasePos_Done								: UINT :=  100; 

	// --------------------------Auto Sequence------------------
	C_SeqStep_Auto_Start										: UINT :=  200;
	C_SeqStep_Auto_End											: UINT :=  400;
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//******* Important and necessary
SUPER^();  
//====================================
IF NOT Enable THEN RETURN; END_IF

]]></ST>
    </Implementation>
    <Folder Name="01 Properties" Id="{eac2aa03-7ea6-4d75-a023-a13fe1428527}" />
    <Folder Name="02 Methodes" Id="{717c44f6-c96e-41a8-89f5-06b22d0c9069}">
