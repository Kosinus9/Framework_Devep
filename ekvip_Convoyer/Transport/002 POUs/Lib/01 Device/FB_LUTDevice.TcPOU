    <Method Name="mCmdExec_Auto" Id="{90a7dbfb-cbde-4eb5-878d-9d7c2e891557}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_Auto : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// hat kein automatique sequence
CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_Auto_Start;
  
  //****************************************************** Start
  C_SeqStep_Auto_Start:
  	
  	SequenceID       :=  C_SeqStep_OnBasePos_Start;
	
  C_SeqStep_Error: 
    //************* all FB reset

		//************* 
  	
 	C_SeqStep_Auto_End:
  	SequenceID := C_SeqStep_Auto_Start;

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_BasePos" Id="{ec212c1f-d213-4550-add5-c0351f9927e9}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_BasePos : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_OnBasePos_Start;
  
  //****************************************************** Start
  C_SeqStep_OnBasePos_Start:
	// Home position for LTU is MIDDLE.
		IF E_CmdState.Succeeded  = fbPneuCyl3Pos_AxisZ.mCallMiddle(TRUE)
			THEN
			Homed := TRUE;
  	  Ready := TRUE;
  	  SequenceID := C_SeqStep_OnBasePos_Done;
		ELSIF E_CmdState.Error = fbPneuCyl3Pos_AxisZ.mCallMiddle(TRUE) THEN
      SequenceID := C_SeqStep_OnBasePos_Error;
		END_IF
		
  C_SeqStep_OnBasePos_Error: 
    //************* all FB reset
    mCmdExec_BasePos := mDone(); 
  //**********************Done
 	C_SeqStep_OnBasePos_Done:
  	mCmdExec_BasePos := mDone();

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_MoveMiddle" Id="{31257785-c557-43e8-9c51-32cde10873f6}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_MoveMiddle : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mCmdExec_MoveMiddle := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to TOP.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallMiddle(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mCmdExec_MoveMiddle := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mCmdExec_MoveMiddle := E_CmdState.Busy;
ELSE
	mCmdExec_MoveMiddle   := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_MoveTop" Id="{4ff0852f-f39d-4fd3-895f-9db63096116e}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_MoveTop : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mCmdExec_MoveTop    := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to TOP.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallTop(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mCmdExec_MoveTop    := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mCmdExec_MoveTop    := E_CmdState.Busy;
ELSE
	mCmdExec_MoveTop      := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_Service" Id="{b17d27f6-62e0-420a-b1d7-d447cfe9cb9d}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_Service : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
 Ready 								:= TRUE;
 SequenceBusy 				:= FALSE;
 SequenceDone 				:= TRUE;
 SequenceID 					:= C_SeqStep_Idle;
 mCmdExec_Service 		:= E_CmdState.Succeeded;
 RETURN;]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_TransferTop" Id="{d2f6dd01-c2ed-4343-891b-6738e835be35}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_TransferTop : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute THEN
    fbLUTSimpleMotor.mStopMotor(TRUE);
    mCmdExec_TransferTop := E_CmdState.Idle;
    RETURN;
END_IF

// Start LTU motor for top transfer.
fbLUTSimpleMotor.mStartMotor(TRUE);
fbStopperLtu.mCallWork(TRUE); // to leave Ltu

// Wait  carrier leaves Ltu.
IF NOT fbStopperLtu.CarriePresent 
	THEN
		fbStopperLtu.mCallBase(TRUE); // Ltu to Top 
    fbLUTSimpleMotor.mStopMotor(TRUE);  // motor aus 
    mCmdExec_TransferTop := E_CmdState.Succeeded;
    RETURN;
END_IF

mCmdExec_TransferTop := E_CmdState.Busy;]]></ST>
      </Implementation>
    </Method>
    <Method Name="mGetLTUByConvoyer" Id="{8febe5ee-97da-4ab2-9486-5866194a4d14}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mGetLTUByConvoyer : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mGetLTUByConvoyer := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to Bottom.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallBottom(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mGetLTUByConvoyer := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mGetLTUByConvoyer := E_CmdState.Busy;
ELSE
	mGetLTUByConvoyer   := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
