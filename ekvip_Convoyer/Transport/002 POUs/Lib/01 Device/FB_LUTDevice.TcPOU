  <POU Name="FB_LUTDevice" Id="{1d37f6f4-ced3-4fc7-b8fb-537fe5b0ee0b}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_LUTDevice EXTENDS FD_Device IMPLEMENTS ITF_LTU
VAR_INPUT
END_VAR

VAR_OUTPUT
END_VAR

VAR
	//===================== Variable
	eLTUPosition					: E_LTUPosition;
	bCarrierPresent				: BOOL;
	bLTUFree							: BOOL;
	
	bReserved							: BOOL;
	eReservedBy						: E_Convoyer;
	
	//===================== Instance
	fbPneuCyl3Pos_AxisZ								: FB_PneuCyl_3Pos     	  (GVL_Customer.C_Name_LTUPneuClyZ,
																															GVL_Customer.C_ID_LTUPneuClyZ
																										  				); 
																													
	fbStopperLtu											: FB_PneuCyl_Stopper      (GVL_Customer.C_Name_LUTStopper,
																															GVL_Customer.C_ID_LUTStopper
																										  			  );																												
																													
	fbLUTLightBarrier									: FB_Input					  		(GVL_Customer.C_Name_LUTLightBarrier,
																															GVL_Customer.C_ID_LUTLightBarrier
																										  				);																																										
	
	fbLUTSimpleMotor									: FB_SimpleMotor      		(GVL_Customer.C_Name_LUTDcMotor,
																															GVL_Customer.C_ID_LUTSimpleMotor
																										  				);
																								
END_VAR

VAR CONSTANT
	// --------------------------Base------------------
	C_SeqStep_OnBasePos_Start								: UINT :=  1; 
	C_SeqStep_OnBasePos_Error								: UINT :=  30;
	C_SeqStep_OnBasePos_Done								: UINT :=  100; 
	
	// --------------------------Auto Sequence------------------
	
	C_SeqStep_Auto_Start										: UINT :=  200;
	C_SeqStep_Auto_End											: UINT :=  400;
END_VAR
	]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//******* Important and necessary
SUPER^();  
//====================================
IF NOT Enable THEN RETURN; END_IF

fbPneuCyl3Pos_AxisZ();
fbStopperLtu();
fbLUTLightBarrier();
fbLUTSimpleMotor();]]></ST>
    </Implementation>
