    <Method Name="mRequestRoute" Id="{4a417486-f8d2-4dd6-9779-5933800df322}" FolderPath="02 Methodes\200 CmdRouteManager\">
      <Declaration><![CDATA[METHOD mRequestRoute : E_CmdState
VAR_INPUT
   I_bExecute     		: BOOL;
   I_eSource      		: E_Convoyer;
   I_eDestination 		: E_Convoyer;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mRequestRoute 			:= E_CmdState.Idle;
    RETURN;         		
END_IF              		
                    		
eSource 								:= I_eSource;
eDestination 					  := I_eDestination;

IF eSource = E_Convoyer.Convoyer_NONE OR 
	 eDestination = E_Convoyer.Convoyer_NONE 
	 	THEN
    	mRequestRoute     := E_CmdState.Error;
    	RETURN;
END_IF

IF NOT mBuildRoute() 
	THEN
    mRequestRoute       := E_CmdState.Error;
    RETURN;
END_IF

IF NOT mCheckRouteFree() 
	THEN
    mRequestRoute 			:= E_CmdState.NotReady;
    RETURN;
END_IF

IF NOT mReserveRoute() 
	THEN
    mRequestRoute 			:= E_CmdState.NotReady;
    RETURN;
END_IF

bRouteAvailable 				:= TRUE;
bRouteReserved 					:= TRUE;

mRequestRoute 					:= E_CmdState.Succeeded;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="mReserveRoute" Id="{b2fe83f5-9021-4c29-a99a-0b7e44acec3e}" FolderPath="02 Methodes\200 CmdRouteManager\">
