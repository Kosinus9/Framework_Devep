    <Method Name="mCmdExec_Auto" Id="{1c6ff37d-c564-4918-a37e-202cb54a1aaf}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_Auto : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_Start;
  
  //****************************************************** Start
  C_SeqStep_Start:
  	
  	SequenceID       :=  C_SeqStep_OnBasePos_Start;
	
  C_SeqStep_Error: 
    //************* all FB reset

		//************* 
  	
 	C_SeqStep_Done:
  	mCmdExec_Auto := mDone();

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_BasePos" Id="{9ccb5bb6-26f1-4044-b8a6-739499d84fd1}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_BasePos : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_Start;
  
  //****************************************************** Start
  C_SeqStep_Start:
	// Home position for LTU is MIDDLE.
		IF E_CmdState.Succeeded  = fbPneuCyl3Pos_AxisZ.mCallMiddle(TRUE)
			THEN
			Homed := TRUE;
  	  Ready := TRUE;
  	  SequenceID := C_SeqStep_OnBasePos_Done;
		END_IF
  C_SeqStep_Error: 
    //************* all FB reset
    mCmdExec_BasePos := mDone(); 
  //**********************Done
 	C_SeqStep_OnBasePos_Done:
  	mCmdExec_BasePos := mDone();

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_MoveBottom" Id="{edd0b7b3-9804-463b-b527-2725182fed5d}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_MoveBottom : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mCmdExec_MoveMiddle := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to TOP.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallBottom(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mCmdExec_MoveBottom := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mCmdExec_MoveBottom := E_CmdState.Busy;
ELSE
	mCmdExec_MoveBottom := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_MoveMiddle" Id="{e4f28548-3151-4b3a-a700-239ef3244658}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_MoveMiddle : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mCmdExec_MoveMiddle := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to TOP.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallMiddle(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mCmdExec_MoveMiddle := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mCmdExec_MoveMiddle := E_CmdState.Busy;
ELSE
	mCmdExec_MoveMiddle := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_MoveTop" Id="{41670507-f4d6-4cdf-a9d2-256dfb7d429c}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_MoveTop : E_CmdState
VAR_INPUT
	I_bExecute					: BOOL;
END_VAR

VAR
	L_eCmdState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// No command requested.
IF NOT I_bExecute 
	THEN
  	mCmdExec_MoveTop := E_CmdState.Idle;
    RETURN;
END_IF

// Move vertical axis to TOP.
L_eCmdState := fbPneuCyl3Pos_AxisZ.mCallTop(TRUE);
CASE L_eCmdState OF
	E_CmdState.Succeeded:
  	mCmdExec_MoveTop := E_CmdState.Succeeded;
  E_CmdState.Busy:
  	mCmdExec_MoveTop := E_CmdState.Busy;
ELSE
	mCmdExec_MoveTop := L_eCmdState;
END_CASE]]></ST>
      </Implementation>
    </Method>
