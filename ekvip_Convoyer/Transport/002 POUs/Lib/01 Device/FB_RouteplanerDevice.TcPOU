    <Method Name="mSequence" Id="{51899c5d-f9d0-467b-ae20-98dc69beb22e}" FolderPath="02 Methodes\">
      <Declaration><![CDATA[METHOD mSequence : E_CmdState
VAR_INPUT
	I_bExecute				: BOOL;
END_VAR

VAR
	L_eState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[mSequence := SUPER^.mSequence(I_bExecute);	


// Generic checks from parent
L_eState := SUPER^.mSequence(I_bExecute := I_bExecute);

IF L_eState <> E_CmdState.Busy 
	THEN
    mSequence := L_eState;
    RETURN;
END_IF

CASE Mode OF
	E_Mode.Homing:
		mCmdExec_Homing();
		
	E_Mode.Auto:
		mCmdExec_Auto();
		
	E_Mode.Homing:
		mCmdExec_Service();
		
END_CASE]]></ST>
      </Implementation>
    </Method>
