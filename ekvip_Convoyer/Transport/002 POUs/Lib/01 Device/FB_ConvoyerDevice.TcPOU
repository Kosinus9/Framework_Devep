    <Method Name="mSequence" Id="{3b40ca71-71ef-49e1-9faa-1a629e293a02}" FolderPath="02 Methodes\">
      <Declaration><![CDATA[METHOD mSequence : E_CmdState
VAR_INPUT
	I_bExecute				: BOOL;
END_VAR

VAR
	L_eState 					: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[mSequence := SUPER^.mSequence(I_bExecute);	


// Generic checks from parent
L_eState := SUPER^.mSequence(I_bExecute := I_bExecute);

IF L_eState <> E_CmdState.Busy 
	THEN
    mSequence := L_eState;
    RETURN;
END_IF

CASE Mode OF
	E_Mode.Homing:
		mSequence := mCmdExec_BasePos();
	E_Mode.Auto:
		mSequence := mCmdExec_Auto();
	E_Mode.Service:
		mSequence := mCmdExec_Service();	
END_CASE]]></ST>
      </Implementation>
    </Method>
