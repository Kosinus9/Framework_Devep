  <POU Name="FB_ConvoyerDevice" Id="{f58c6f5d-3b14-41fa-923e-c299a6fe3b56}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ConvoyerDevice EXTENDS FD_Device IMPLEMENTS ITF_Convoyer
VAR_INPUT
END_VAR

VAR_OUTPUT
END_VAR

VAR 
	//===================== Variable
	eSource 						 : E_Convoyer;
  eDestination 				 : E_Convoyer;
	
	bRouteRequest				 : BOOL;
	bCarrierWaiting   	 : BOOL;
	bRouteGranted 			 : BOOL;
	
	bTranspOutRequest    : BOOL;
	bTranspOutBusy       : BOOL;
	bTranspOutDone       : BOOL;
	
	//===================== Instance
	fbStopperCarrieConvoyer						: FB_PneuCyl_Stopper  (GVL_Customer.C_Name_StopperCarrieConvoyer,
																													GVL_Customer.C_ID_StopperCarrieConvoyer
																										  		);																												
																												
	fbMotorConvoyer										: FB_SimpleMotor      (GVL_Customer.C_Name_ConvoyerDcMotor,
																													 GVL_Customer.C_ID_MotorComvoyer
																										  		);
																													
	fbReadHead												: FB_ReadHead        	(GVL_Customer.C_Name_ReadHead,
																													GVL_Customer.C_ID_ReadHead
																										  		); 
																													
END_VAR

VAR CONSTANT
	// --------------------------Base------------------
	C_SeqStep_OnBasePos_Start															: UINT :=  20; 
	C_SeqStep_OnBasePos_WaitOpMode												: UINT :=  30;
	C_SeqStep_OnBasePos_Done															: UINT :=  40; 
	
	// --------------------------Auto Sequence------------------
	C_SeqStep_Auto_Start																	: UINT :=  100;
	C_SeqStep_Auto_Wait_Carrier_At_Stopper								: UINT :=  110;
	C_SeqStep_Auto_Read_Destination_Once									: UINT :=  120;
	C_SeqStep_Auto_Ask_RouteManager_For_A_Route						: UINT :=  130;
	C_SeqStep_Auto_Inject_Carrier_IntoGranted_Route				: UINT :=  140;
	C_SeqStep_Auto_End																		: UINT :=  150;
	
END_VAR
	]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//******* Important and necessary
SUPER^();  
//====================================
IF NOT Enable THEN RETURN; END_IF

fbStopperCarrieConvoyer();
fbMotorConvoyer();
fbReadHead();
]]></ST>
    </Implementation>
