END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_Auto" Id="{973859fe-6ada-4c64-963f-bf319c88cc9e}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_Auto : E_CmdState
VAR_INPUT
END_VAR

VAR
    L_eCmd 			: E_CmdState;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_Start;
  
  //****************************************************** Start
  C_SeqStep_Start:
		bRouteRequest 			:= FALSE;
    bRouteGranted 			:= FALSE;
    bTranspOutRequest 	:= FALSE;
    bTranspOutDone 			:= FALSE; 	
  	SequenceID          := C_SeqStep_Auto_Wait_Carrier_At_Stopper;
		
	C_SeqStep_Auto_Wait_Carrier_At_Stopper :
	
	IF fbStopperCarrieConvoyer.CarriePresent 
		THEN
      SequenceID := C_SeqStep_Auto_Read_Destination_Once;
  END_IF
	
	C_SeqStep_Auto_Read_Destination_Once:
	// Read destination one.
  	IF fbReadHead.mRead() = E_CmdState.Succeeded 
			THEN
  	    eDestination 		:= fbReadHead.ReadDestination;
  	    SequenceID 			:= C_SeqStep_Auto_Ask_RouteManager_For_A_Route;
  	END_IF
	
	C_SeqStep_Auto_Ask_RouteManager_For_A_Route:
	// Ask RouteManager for a route.
 		bRouteRequest := TRUE;
		
    IF bRouteGranted 
			THEN
    		bTranspOutRequest  := TRUE;
    	  SequenceID         := C_SeqStep_Auto_Inject_Carrier_IntoGranted_Route;
    	END_IF

	 C_SeqStep_Auto_Inject_Carrier_IntoGranted_Route:
      // Inject carrier into granted route.				
		IF mCmdExec_TranspOut(bTranspOutRequest ) = E_CmdState.Succeeded 
			THEN
      	bRouteRequest := FALSE;
      	bRouteGranted := FALSE;
      	bTranspOutRequest := FALSE;
      	SequenceID := C_SeqStep_Auto_End;
     END_IF
									
  C_SeqStep_Error: 
    //************* all FB reset
 
 	C_SeqStep_Auto_End:
	  //**********************End 
		SequenceID := C_SeqStep_Start;
  		
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_BasePos" Id="{eb2de01f-87e9-4e47-9b8c-605e0a054e34}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_BasePos : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE SequenceID OF

  //******************************************************* Idle 
  C_SeqStep_Idle: 
  	SequenceID       :=  C_SeqStep_Start;
  
  //****************************************************** Start
  C_SeqStep_Start:
	// Home position for LTU is MIDDLE.
		fbMotorConvoyer.mStopMotor(TRUE);
		IF E_CmdState.Succeeded  = fbStopperCarrieConvoyer.mCallBase(TRUE)
			THEN
			Homed := TRUE;
  	  Ready := TRUE;
  	  SequenceID := C_SeqStep_OnBasePos_Done;
		END_IF
		
  C_SeqStep_Error: 
    //************* all FB reset
    mCmdExec_BasePos := mDone(); 
  //**********************Done
 	C_SeqStep_OnBasePos_Done:
  	mCmdExec_BasePos := mDone();

END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_Service" Id="{d322bdec-4501-4078-818a-8eafd3a95f6f}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_Service : E_CmdState
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[;]]></ST>
      </Implementation>
    </Method>
    <Method Name="mCmdExec_TranspOut" Id="{2bdddac8-0ea5-442f-81c6-6021ed68c775}" FolderPath="02 Methodes\100 CmdExecute\">
      <Declaration><![CDATA[METHOD mCmdExec_TranspOut : E_CmdState
VAR_INPUT
	I_bExecute 			: BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT I_bExecute 
	THEN
    bTranspOutBusy := FALSE;
    mCmdExec_TranspOut := E_CmdState.Idle;
    RETURN;
END_IF

// Route not granted yet.
// Route noch nicht freigegeben
IF NOT bRouteGranted 
	THEN
  	mCmdExec_TranspOut := E_CmdState.NotReady;
    RETURN;
END_IF

bTranspOutBusy := TRUE;
bTranspOutDone := FALSE;

// Open stopper: stopper down = carrier can pass.
fbStopperCarrieConvoyer.mCallWork(TRUE);

// Start conveyor motor.
fbMotorConvoyer.mStartMotor(TRUE);

// Wait until carrier leaves stopper sensor.
IF NOT fbStopperCarrieConvoyer.CarriePresent 
	THEN
  	// Stop local injection.
  	fbMotorConvoyer.mStopMotor(TRUE);
		
  	// Close stopper again.
  	fbStopperCarrieConvoyer.mCallBase(TRUE);
  	bTranspOutBusy := FALSE;
  	bTranspOutDone := TRUE;
  	mCmdExec_TranspOut := E_CmdState.Succeeded;
  	RETURN;
END_IF
]]></ST>
      </Implementation>
    </Method>
