<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FM_Maschine" Id="{83e5710c-69e8-4593-a566-ae4a485f5caa}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK ABSTRACT FM_Maschine EXTENDS FD_Device 
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	// Global child status
	bAllChildsReady 					: BOOL;
	bAllChildsHomed 					: BOOL;
	bAllChildsDone  					: BOOL;
	bAnyChildBusy   					: BOOL;
	bAnyChildError  					: BOOL;
	// Internal command state
	eLastChildCmdState 				: E_CmdState;
	
	// Hmi Variable
	stHMI 										: ST_MaschineHMI;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
SUPER^();  
IF NOT Enable THEN RETURN; END_IF;

mVisu();
// Update global child status every PLC cycle
mUpdateChildsState();

IF SequenceBusy THEN
    mSequence(TRUE);
END_IF]]></ST>
    </Implementation>
    <Folder Name="01 Properties" Id="{6a87ee5d-b4db-4b64-8036-f307a328febf}" />
    <Folder Name="02 Methodes" Id="{5561014d-7db8-4950-aa75-2604d264aa2f}">
