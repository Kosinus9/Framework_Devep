    <Method Name="mEnable" Id="{5ac26998-73d7-403c-92b8-3bfaf4bc5e70}" FolderPath="02 Methods\">
      <Declaration><![CDATA[METHOD mEnable : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
IF NOT bEnable THEN
    mEnable := FALSE;
    RETURN;
END_IF

IF bError THEN
    mEnable := FALSE;
    RETURN;
END_IF

mEnable := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="mInit" Id="{85ac23e9-5592-4108-b8d8-74958e7f3617}" FolderPath="02 Methods\">
      <Declaration><![CDATA[METHOD mInit : BOOL
VAR_INPUT

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
bBusy 					:= FALSE;
bDone 					:= FALSE;
bError 					:= FALSE;
sErrorMessage 	:= '';

mInit 					:= TRUE;
]]></ST>
      </Implementation>
    </Method>
