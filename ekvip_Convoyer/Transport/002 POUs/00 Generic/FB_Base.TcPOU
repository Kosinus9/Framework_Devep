<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_Base" Id="{b834a18a-92ee-42a2-95e8-764f580bbbef}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK ABSTRACT FB_Base IMPLEMENTS ITF_Base

VAR
	sName          										: STRING;
	uiId           										: UINT;
	
	              										
	bEnable        										: BOOL := TRUE;
	bInit          										: BOOL;
	bBusy          										: BOOL;
	bDone          										: BOOL;
	bError         										: BOOL;
	sErrorMessage  										: STRING;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
IF NOT Init
  THEN Init := mInit();
END_IF

mVisu();

Enable := Enable;
IF NOT Enable 
	THEN 
		bBusy := FALSE;
		bDone := FALSE;
		RETURN; 
END_IF

mEnable();
]]></ST>
    </Implementation>
